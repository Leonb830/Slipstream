{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "staticDistDir": "web"
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "resource-summary:script:size": ["warn", { "maxNumericValue": 170000 }],
        "resource-summary:image:size": ["warn", { "maxNumericValue": 220000 }]
      }
    }
  }
}
